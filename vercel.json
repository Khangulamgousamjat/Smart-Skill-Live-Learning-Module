{
  "version": 2,
  "public": false,
  "buildCommand": "cd app_frontend && npm run build",
  "installCommand": "cd app_frontend && npm install",
  "outputDirectory": "app_frontend/dist",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/((?!assets/|favicon.ico|.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
